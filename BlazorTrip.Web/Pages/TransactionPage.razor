@page "/transactions"
@using BlazorTrip.Application.Dto
@using BlazorTrip.Application.ViewModels
@using BlazorTrip.Domain.Models
@using BlazorTrip.Web.WebApis
@inject TransactionPageViewModel ViewModel
@inject PopoverApi PopoverApi
@implements IDisposable

<div class="app-page">

    <PageHeader
        Title="Lançamentos"
        SubTitle="Valores que foram gastos na viagem"
        IconName="ph ph-receipt"/>

    <div @ref="_popoverNew" class="c-component-popover" popover="manual" id="new-transaction-form">
        <NewTransactionCard
            Categories="ViewModel.Categories"
            People="ViewModel.People"
            OnSubmit="Submit"
            OnClose="ClosePopover"/>
    </div>

    <div style="display: flex; justify-content: space-between; gap: 1rem; margin-bottom: 1rem">

        <div class="app-search-container">
            <input class="app-input" @bind="ViewModel.Search" @bind:event="oninput" placeholder="Pesquise aqui..."/>
            <i class="ph ph-magnifying-glass"></i>
        </div>

        <button class="app-button" popovertarget="new-transaction-form">
            <i class="ph ph-plus"></i>
            NOVO
        </button>
    </div>

    <TransactionTable Transactions="ViewModel.Transactions"
                      OnDelete="Delete"
                      OnEdit="SelectToUpdate"/>

    <AppModal Visible="ViewModel.IsUpdateVisible" VisibleChanged="UnselectToUpdate">
        @if (ViewModel.SelectedTransaction is not null)
        {
            <UpdateTransactionCard
                Categories="ViewModel.Categories"
                People="ViewModel.People"
                OnSubmit="Update"
                OnClose="UnselectToUpdate"
                Transaction="ViewModel.SelectedTransaction"/>
        }
    </AppModal>
</div>

@code
{
    private void UpdateUi(object? sender, EventArgs args) => InvokeAsync(StateHasChanged);

    private ElementReference _popoverNew;

    private async Task ClosePopover()
    {
        await PopoverApi.Close(_popoverNew);
    }

    protected override void OnInitialized()
    {
        ViewModel.PropertyChanged += UpdateUi;
        ViewModel.Transactions.CollectionChanged += UpdateUi;
        ViewModel.LoadCommand.Execute(null);
    }

    private void SelectToUpdate(TransactionDto dto)
    {
        ViewModel.SelectTransactionCommand.Execute(dto);
    }

    private void UnselectToUpdate()
    {
        ViewModel.UnselectTransactionCommand.Execute(null);
    }

    private void Update(Transaction transaction)
    {
        ViewModel.UpdateTransactionCommand.Execute(transaction);
    }

    private void Submit(CreateTransactionDto dto)
    {
        ViewModel.CreateTransactionCommand.Execute(dto);
    }

    private void Delete(TransactionDto dto)
    {
        ViewModel.DeleteTransactionCommand.Execute(dto.Id);
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= UpdateUi;
        ViewModel.Transactions.CollectionChanged -= UpdateUi;
    }
}
